# Normalize line endings to LF in the repo (consistent on Linux deploys).
* text=auto eol=lf

# Treat media as binary (no line-ending conversion / diffing).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.avif binary
*.ico  binary
*.mp4  binary
*.mov  binary
*.woff binary
*.woff2 binary
