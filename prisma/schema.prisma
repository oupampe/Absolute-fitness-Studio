// Absolute Fitness Studio — Prisma schema
// Postgres on Supabase. TWO connection strings required (see .env.example):
//   DATABASE_URL = pooled (port 6543, ?pgbouncer=true) — runtime
//   DIRECT_URL   = direct  (port 5432)                 — migrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Auth.js (NextAuth) core models ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Credentials provider (email/password) — null for OAuth-only users
  passwordHash  String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  subscription    Subscription?
  paymentRequests PaymentRequest[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Subscriptions & manual payments ----------

enum Plan {
  NONE
  BOOTCAMP
  GROUP
  PRIVATE
}

enum SubStatus {
  PENDING
  ACTIVE
  CANCELLED
}

enum PaymentMethod {
  NONE
  MANUAL_EFT
  CARD
}

enum RequestStatus {
  NEW
  RESPONDED
}

model Subscription {
  id            String        @id @default(cuid())
  userId        String        @unique
  plan          Plan          @default(NONE)
  status        SubStatus     @default(PENDING)
  paymentMethod PaymentMethod @default(NONE)
  startedAt     DateTime?
  renewsAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentRequest {
  id        String        @id @default(cuid())
  userId    String
  plan      Plan
  amount    Int? // in ZAR rand; null for "plan based" offerings
  message   String        @db.Text
  status    RequestStatus @default(NEW)
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
